    disable)             cmd_disable            "$@" ;;
    reload)              cmd_reload             "$@" ;;
    list-json)            cmd_list_json          "$@" ;;
    toggle)               cmd_toggle             "$@" ;;
    voices)              cmd_voices             "$@" ;;
    add)                  cmd_add                "$@" ;;
    add-file)             cmd_add_file           "$@" ;;
    edit-rotation)        cmd_edit_rotation      "$@" ;;
    reorder-rotation)     cmd_reorder_rotation   "$@" ;;
    list)                 cmd_list               "$@" ;;
    remove)               cmd_remove             "$@" ;;
    play)                 cmd_play               "$@" ;;
    add-schedule)         cmd_add_schedule       "$@" ;;
    add-schedule-file)    cmd_add_schedule_file  "$@" ;;
    edit-schedule)        cmd_edit_schedule      "$@" ;;
    toggle-schedule)      cmd_toggle_schedule    "$@" ;;
    toggle-rotation)      cmd_toggle_rotation    "$@" ;;
    update-settings)      cmd_update_settings    "$@" ;;
    update-timeweather)   cmd_update_timeweather "$@" ;;
    test-timeweather)     cmd_test_timeweather   "$@" ;;
    playback-history)     cmd_playback_history   "$@" ;;
    clear-history)        cmd_clear_history      "$@" ;;
    export-config)        cmd_export_config      "$@" ;;
