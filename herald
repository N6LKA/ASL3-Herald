#!/usr/bin/env bash
# herald — management command for asl3-herald

INSTALL_DIR="/etc/asterisk/scripts/asl3-herald"
CONF_FILE="$INSTALL_DIR/asl3-herald.conf"
SERVICE="asl3-herald"
ANNOUNCE_DIR="$INSTALL_DIR/announcements"
DISABLE_FLAG="$INSTALL_DIR/asl3-herald-disabled"
DAEMON_PY="/usr/local/bin/asl3-herald/asl3-herald.py"
PIPER_BIN="/opt/piper/bin/piper/piper"
PIPER_VOICE_DIR="/opt/piper/voices"

usage() {
    cat <<EOF
Usage: herald <command> [options]

General:
  status                                  Show daemon status and config summary
  enable                                  Remove disable flag and start daemon
  disable                                 Stop daemon and set disable flag
  toggle                                  Flip enabled/disabled state
  reload                                  Reload config without restarting (SIGHUP)
  list-json                               Print config as JSON (used by the web UI)
  voices [--json]                         List available TTS voices
  help                                    Show this message

Tail Messages (unkey-triggered rotation):
  add "<text>" [--name <name>] [--voice <voice>]
                                           Generate TTS announcement and add to rotation
  add-file <path> [--name <name>]         Copy an existing WAV file into rotation
  edit-rotation <name> [--new-name <n>] [--text "<text>"] [--voice <v>] [--file <path>]
                                           Edit an existing rotation entry
  list                                    List rotation + scheduled announcements
  remove <name>                           Remove a rotation file or scheduled announcement
  play <name>                             Play an announcement immediately on the node

Scheduled Announcements (clock-triggered):
  add-schedule "<text>" --name <name> --time HH:MM [--days daily|d1,d2] [--week 1-5]
               [--voice <voice>] [--play-mode local|global]
                                           Generate TTS announcement and schedule it
  add-schedule-file <path> --name <name> --time HH:MM [--days daily|d1,d2] [--week 1-5]
                     [--play-mode local|global]
                                           Schedule an existing WAV file
  edit-schedule <name> [--new-name <n>] [--time HH:MM] [--days ...] [--week 1-5]
                [--play-mode local|global] [--text "<text>"] [--voice <v>] [--file <path>]
                                           Edit an existing scheduled announcement

Settings:
  update-settings [--node <n>] [--poll-interval <n>] [--debug true|false]
                  [--min-interval <n>] [--swp-enable true|false]
                  [--swp-wxfile <path>] [--swp-threshold <n>]
                                           Update general daemon settings
EOF
}

need_root() {
    if [[ $EUID -ne 0 ]]; then
        echo "This command requires root. Use: sudo herald $*"
        exit 1
    fi
}

json_get() {
    # json_get <jq-ish python path expression on the parsed dict, e.g. "d['node']">
    python3 -c "
import json, sys
d = json.load(sys.stdin)
try:
    print($1)
except Exception:
    print('')
"
}

daemon_list_json() {
    python3 "$DAEMON_PY" list-json 2>/dev/null
}

get_node() {
    daemon_list_json | json_get "d['node']"
}

# ── TTS generation (shared by add and add-schedule) ───────────────────────────
# Writes text to $ANNOUNCE_DIR/<name>.wav using Piper (preferred), falling back
# to festival or espeak-ng. Prints the resulting file path on success.
generate_tts_file() {
    local text="$1" name="$2" voice="$3"
    mkdir -p "$ANNOUNCE_DIR"
    local outfile="$ANNOUNCE_DIR/${name}.wav"

    if [[ -x "$PIPER_BIN" ]]; then
        local model="$PIPER_VOICE_DIR/en_US-lessac-medium.onnx"
        if [[ -n "$voice" ]]; then
            if [[ -f "$PIPER_VOICE_DIR/${voice}.onnx" ]]; then
                model="$PIPER_VOICE_DIR/${voice}.onnx"
            elif [[ -f "$voice" ]]; then
                model="$voice"
            else
                echo "WARNING: voice '$voice' not found, using default (lessac)" >&2
            fi
        fi
        local tmp_wav
        tmp_wav="$(mktemp --suffix=.wav)"
        export LD_LIBRARY_PATH="/opt/piper/bin:${LD_LIBRARY_PATH:-}"
        # Piper prints its own status (including the --output_file path) to
        # stdout, which would otherwise get captured by the "outfile=$(...)"
        # call site along with our own final echo below - corrupting the
        # returned path. Suppress it entirely; our own >&2 lines are the
        # only intended diagnostic output.
        echo "$text" | "$PIPER_BIN" --model "$model" --output_file "$tmp_wav" >/dev/null 2>&1
        sox "$tmp_wav" -r 8000 -c 1 -b 16 -t wav "$outfile" >/dev/null 2>&1
        rm -f "$tmp_wav"
        echo "Generated with Piper TTS ($(basename "$model" .onnx)): $outfile" >&2
    elif command -v text2wave &>/dev/null && command -v sox &>/dev/null; then
        local tmp_wav
        tmp_wav="$(mktemp --suffix=.wav)"
        echo "$text" | text2wave -o "$tmp_wav" >/dev/null 2>&1
        sox "$tmp_wav" -r 8000 -c 1 -b 16 -t wav "$outfile" >/dev/null 2>&1
        rm -f "$tmp_wav"
        echo "Generated with festival TTS: $outfile" >&2
    elif command -v espeak-ng &>/dev/null && command -v sox &>/dev/null; then
        espeak-ng -s 140 -a 150 --stdout "$text" 2>/dev/null | sox -t wav - -r 8000 -c 1 -b 16 -t wav "$outfile" >/dev/null 2>&1
        echo "Generated with espeak-ng TTS: $outfile" >&2
    else
        echo "ERROR: No TTS engine found. Install Piper (see install.sh), festival + sox, or espeak-ng + sox." >&2
        return 1
    fi

    if [[ ! -s "$outfile" ]]; then
        echo "ERROR: TTS output file is empty. Check TTS installation." >&2
        return 1
    fi

    echo "$outfile"
}

slugify() {
    echo "$1" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd 'a-z0-9-' | cut -c1-40
}

# ── General commands ───────────────────────────────────────────────────────────

cmd_status() {
    if systemctl is-active --quiet "$SERVICE"; then
        echo "Service:   running"
    else
        echo "Service:   stopped"
    fi

    if [[ -f "$DISABLE_FLAG" ]]; then
        echo "Herald:    DISABLED (disable flag present)"
    else
        echo "Herald:    enabled"
    fi

    local info
    info="$(daemon_list_json)"
    if [[ -n "$info" ]]; then
        echo "Node:      $(echo "$info" | json_get "d['node']")"
        echo "MinInterval: $(echo "$info" | json_get "d['tail_message']['min_interval']")s"
        echo "SkywarnPlus: $(echo "$info" | json_get "d['tail_message']['skywarnplus']['enable']")"
        echo "Rotation entries:  $(echo "$info" | json_get "len(d['tail_message']['rotation'])")"
        echo "Scheduled entries: $(echo "$info" | json_get "len(d['scheduled'])")"
    else
        echo "Node:      <config unreadable>"
    fi

    echo ""
    systemctl status "$SERVICE" --no-pager -l 2>&1 | tail -20
}

cmd_enable() {
    need_root "$@"
    if [[ -f "$DISABLE_FLAG" ]]; then
        rm -f "$DISABLE_FLAG"
        echo "Disable flag removed."
    fi
    systemctl start "$SERVICE" 2>/dev/null || true
    systemctl enable "$SERVICE" 2>/dev/null || true
    echo "asl3-herald enabled and started."
}

cmd_disable() {
    need_root "$@"
    touch "$DISABLE_FLAG"
    echo "Disable flag set. Herald will suppress tail messages."
    echo "To also stop the service: sudo systemctl stop $SERVICE"
}

cmd_reload() {
    need_root "$@"
    if systemctl is-active --quiet "$SERVICE"; then
        systemctl kill -s HUP "$SERVICE"
        echo "SIGHUP sent — config reloaded."
    else
        echo "Service is not running. Start it first: sudo systemctl start $SERVICE"
    fi
}

cmd_list_json() {
    # Read-only JSON passthrough for the web UI — no root required.
    daemon_list_json
}

cmd_toggle() {
    need_root "$@"
    if [[ -f "$DISABLE_FLAG" ]]; then
        cmd_enable
    else
        cmd_disable
    fi
}

cmd_voices() {
    local json_mode=false
    [[ "${1:-}" == "--json" ]] && json_mode=true

    if [[ ! -x "$PIPER_BIN" ]]; then
        if $json_mode; then
            echo '{"voices": []}'
        else
            echo "Piper TTS is not installed. Re-run install.sh to add it."
            echo "Falling back to: festival (if installed) or espeak-ng (if installed)."
        fi
        return
    fi

    if $json_mode; then
        local names=()
        if compgen -G "$PIPER_VOICE_DIR/*.onnx" > /dev/null; then
            for f in "$PIPER_VOICE_DIR"/*.onnx; do
                names+=("\"$(basename "$f" .onnx)\"")
            done
        fi
        local joined
        joined=$(IFS=,; echo "${names[*]}")
        echo "{\"voices\": [$joined]}"
        return
    fi

    echo "=== Piper voices ($PIPER_VOICE_DIR) ==="
    if compgen -G "$PIPER_VOICE_DIR/*.onnx" > /dev/null; then
        for f in "$PIPER_VOICE_DIR"/*.onnx; do
            echo "  $(basename "$f" .onnx)"
        done
    else
        echo "  (none installed)"
    fi
}

# ── Tail message (rotation) commands ──────────────────────────────────────────

cmd_add() {
    need_root "$@"
    local text="" name="" voice=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --name)  name="$2";  shift 2 ;;
            --voice) voice="$2"; shift 2 ;;
            *) text="$1"; shift ;;
        esac
    done

    if [[ -z "$text" ]]; then
        echo "Usage: herald add \"<text>\" [--name <name>] [--voice <voice>]"
        exit 1
    fi
    [[ -z "$name" ]] && name="$(slugify "$text")"

    local outfile
    outfile="$(generate_tts_file "$text" "$name" "$voice")" || exit 1

    local args=(add-rotation "$outfile" --text "$text")
    [[ -n "$voice" ]] && args+=(--voice "$voice")
    python3 "$DAEMON_PY" "${args[@]}"
    cmd_reload 2>/dev/null || true
}

cmd_add_file() {
    need_root "$@"
    local src="" name=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --name) name="$2"; shift 2 ;;
            *) src="$1"; shift ;;
        esac
    done

    if [[ -z "$src" ]]; then
        echo "Usage: herald add-file <path> [--name <name>]"
        exit 1
    fi
    if [[ ! -f "$src" ]]; then
        echo "ERROR: File not found: $src"
        exit 1
    fi
    [[ -z "$name" ]] && name="$(basename "$src" .wav)"

    mkdir -p "$ANNOUNCE_DIR"
    local dest="$ANNOUNCE_DIR/${name}.wav"
    cp "$src" "$dest"
    echo "Copied to: $dest"

    python3 "$DAEMON_PY" add-rotation "$dest"
    cmd_reload 2>/dev/null || true
}

cmd_edit_rotation() {
    need_root "$@"
    local old_name="" new_name="" text="" voice="" file="" has_text=false has_file=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --new-name) new_name="$2"; shift 2 ;;
            --text)     text="$2"; has_text=true; shift 2 ;;
            --voice)    voice="$2"; shift 2 ;;
            --file)     file="$2"; has_file=true; shift 2 ;;
            *) old_name="$1"; shift ;;
        esac
    done

    if [[ -z "$old_name" ]]; then
        echo 'Usage: herald edit-rotation <name> [--new-name <n>] [--text "<text>"] [--voice <v>] [--file <path>]'
        exit 1
    fi
    [[ -z "$new_name" ]] && new_name="$old_name"

    local old_wav="$ANNOUNCE_DIR/${old_name}.wav"
    local new_wav="$ANNOUNCE_DIR/${new_name}.wav"

    if $has_text; then
        generate_tts_file "$text" "$new_name" "$voice" >/dev/null || exit 1
        [[ "$old_name" != "$new_name" && -f "$old_wav" ]] && rm -f "$old_wav"
    elif $has_file; then
        mkdir -p "$ANNOUNCE_DIR"
        cp "$file" "$new_wav"
        [[ "$old_name" != "$new_name" && -f "$old_wav" ]] && rm -f "$old_wav"
    elif [[ "$old_name" != "$new_name" && -f "$old_wav" ]]; then
        # Rename only - no new text/audio, keep the existing file content.
        mv "$old_wav" "$new_wav"
    fi

    local args=(edit-rotation "$old_name" --new-name "$new_name" --file "$new_wav")
    $has_text && args+=(--text "$text")
    [[ -n "$voice" ]] && args+=(--voice "$voice")
    python3 "$DAEMON_PY" "${args[@]}"
    cmd_reload 2>/dev/null || true
}

cmd_list() {
    local info
    info="$(daemon_list_json)"
    if [[ -z "$info" ]]; then
        echo "ERROR: Could not read config."
        exit 1
    fi

    echo "=== Tail Messages (Rotation) ==="
    echo "$info" | python3 -c "
import json, sys
d = json.load(sys.stdin)
rot = d['tail_message']['rotation']
if not rot:
    print('  (none)')
for i, f in enumerate(rot, 1):
    print(f'  {i}. {f}')
"

    echo ""
    echo "=== Scheduled Announcements ==="
    echo "$info" | python3 -c "
import json, sys
d = json.load(sys.stdin)
sched = d['scheduled']
if not sched:
    print('  (none)')
for s in sched:
    days = s.get('Days', 'daily')
    days = days if isinstance(days, str) else ','.join(days)
    week = f\" (week {s['Week']})\" if s.get('Week') else ''
    print(f\"  {s.get('Name','?')} — {s.get('Time','?')} {days}{week} — {s.get('File','?')}\")
"
}

cmd_remove() {
    need_root "$@"
    local name="$1"
    if [[ -z "$name" ]]; then
        echo "Usage: herald remove <name>"
        exit 1
    fi

    python3 "$DAEMON_PY" remove "$name"
    cmd_reload 2>/dev/null || true

    local wavfile="$ANNOUNCE_DIR/${name}.wav"
    if [[ -f "$wavfile" ]]; then
        rm -f "$wavfile"
        echo "Deleted: $wavfile"
    fi
}

cmd_update_settings() {
    need_root "$@"
    python3 "$DAEMON_PY" update-settings "$@"
    cmd_reload 2>/dev/null || true
}

cmd_play() {
    need_root "$@"
    local name="$1"
    if [[ -z "$name" ]]; then
        echo "Usage: herald play <name>"
        exit 1
    fi

    local wavfile="$ANNOUNCE_DIR/${name}.wav"
    if [[ ! -f "$wavfile" ]]; then
        echo "ERROR: File not found: $wavfile"
        exit 1
    fi

    local node
    node="$(get_node)"
    if [[ -z "$node" ]]; then
        echo "ERROR: Node not set in config."
        exit 1
    fi

    # Rotation entries always play locally; a scheduled announcement may be
    # configured for global (network-wide) playback instead.
    local play_mode
    play_mode="$(daemon_list_json | json_get "next((s.get('PlayMode','local') for s in d['scheduled'] if s.get('Name')=='$name'), 'local')")"
    [[ -z "$play_mode" ]] && play_mode="local"

    local rpt_cmd="rpt localplay"
    [[ "$play_mode" == "global" ]] && rpt_cmd="rpt playback"

    local path_no_ext="${wavfile%.wav}"
    echo "Playing $name on node $node (mode: $play_mode) ..."
    asterisk -rx "$rpt_cmd $node $path_no_ext"
}

# ── Scheduled announcement commands ───────────────────────────────────────────

parse_schedule_opts() {
    # Parses --name --time --days --week --play-mode from "$@", leaving the
    # remainder (text or filepath) in REMAINDER.
    name="" time="" days="daily" week="" play_mode=""
    REMAINDER=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --name)      name="$2";  shift 2 ;;
            --time)      time="$2";  shift 2 ;;
            --days)      days="$2";  shift 2 ;;
            --week)      week="$2";  shift 2 ;;
            --voice)     voice="$2"; shift 2 ;;
            --play-mode) play_mode="$2"; shift 2 ;;
            *) REMAINDER+=("$1"); shift ;;
        esac
    done
}

cmd_add_schedule() {
    need_root "$@"
    local name time days week voice play_mode
    parse_schedule_opts "$@"
    local text="${REMAINDER[*]}"

    if [[ -z "$text" || -z "$name" || -z "$time" ]]; then
        echo 'Usage: herald add-schedule "<text>" --name <name> --time HH:MM [--days daily|d1,d2] [--week 1-5] [--voice <voice>] [--play-mode local|global]'
        exit 1
    fi

    local outfile
    outfile="$(generate_tts_file "$text" "$name" "$voice")" || exit 1

    local args=(add-scheduled --name "$name" --time "$time" --days "$days" --file "$outfile" --text "$text")
    [[ -n "$week" ]] && args+=(--week "$week")
    [[ -n "$voice" ]] && args+=(--voice "$voice")
    [[ -n "$play_mode" ]] && args+=(--play-mode "$play_mode")
    python3 "$DAEMON_PY" "${args[@]}"
    cmd_reload 2>/dev/null || true
}

cmd_add_schedule_file() {
    need_root "$@"
    local name time days week voice play_mode
    parse_schedule_opts "$@"
    local src="${REMAINDER[0]:-}"

    if [[ -z "$src" || -z "$name" || -z "$time" ]]; then
        echo "Usage: herald add-schedule-file <path> --name <name> --time HH:MM [--days daily|d1,d2] [--week 1-5] [--play-mode local|global]"
        exit 1
    fi
    if [[ ! -f "$src" ]]; then
        echo "ERROR: File not found: $src"
        exit 1
    fi

    mkdir -p "$ANNOUNCE_DIR"
    local dest="$ANNOUNCE_DIR/${name}.wav"
    cp "$src" "$dest"
    echo "Copied to: $dest"

    local args=(add-scheduled --name "$name" --time "$time" --days "$days" --file "$dest")
    [[ -n "$week" ]] && args+=(--week "$week")
    [[ -n "$play_mode" ]] && args+=(--play-mode "$play_mode")
    python3 "$DAEMON_PY" "${args[@]}"
    cmd_reload 2>/dev/null || true
}

cmd_edit_schedule() {
    need_root "$@"
    local old_name="" new_name="" time="" days="" week="" play_mode="" text="" voice="" file=""
    local has_text=false has_file=false has_time=false has_days=false has_week=false has_playmode=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --new-name)  new_name="$2"; shift 2 ;;
            --time)      time="$2"; has_time=true; shift 2 ;;
            --days)      days="$2"; has_days=true; shift 2 ;;
            --week)      week="$2"; has_week=true; shift 2 ;;
            --play-mode) play_mode="$2"; has_playmode=true; shift 2 ;;
            --text)      text="$2"; has_text=true; shift 2 ;;
            --voice)     voice="$2"; shift 2 ;;
            --file)      file="$2"; has_file=true; shift 2 ;;
            *) old_name="$1"; shift ;;
        esac
    done

    if [[ -z "$old_name" ]]; then
        echo 'Usage: herald edit-schedule <name> [--new-name <n>] [--time HH:MM] [--days ...] [--week 1-5] [--play-mode local|global] [--text "<text>"] [--voice <v>] [--file <path>]'
        exit 1
    fi
    [[ -z "$new_name" ]] && new_name="$old_name"

    local old_wav="$ANNOUNCE_DIR/${old_name}.wav"
    local new_wav="$ANNOUNCE_DIR/${new_name}.wav"
    local final_file=""

    if $has_text; then
        generate_tts_file "$text" "$new_name" "$voice" >/dev/null || exit 1
        final_file="$new_wav"
        [[ "$old_name" != "$new_name" && -f "$old_wav" ]] && rm -f "$old_wav"
    elif $has_file; then
        mkdir -p "$ANNOUNCE_DIR"
        cp "$file" "$new_wav"
        final_file="$new_wav"
        [[ "$old_name" != "$new_name" && -f "$old_wav" ]] && rm -f "$old_wav"
    elif [[ "$old_name" != "$new_name" && -f "$old_wav" ]]; then
        # Rename only - no new text/audio, keep the existing file content.
        mv "$old_wav" "$new_wav"
        final_file="$new_wav"
    fi

    local args=(edit-scheduled "$old_name" --new-name "$new_name")
    $has_time     && args+=(--time "$time")
    $has_days     && args+=(--days "$days")
    $has_week     && args+=(--week "$week")
    $has_playmode && args+=(--play-mode "$play_mode")
    $has_text     && args+=(--text "$text")
    [[ -n "$voice" ]] && args+=(--voice "$voice")
    [[ -n "$final_file" ]] && args+=(--file "$final_file")

    python3 "$DAEMON_PY" "${args[@]}"
    cmd_reload 2>/dev/null || true
}

# ── Dispatch ───────────────────────────────────────────────────────────────────

CMD="${1:-help}"
shift || true

case "$CMD" in
    status)             cmd_status             "$@" ;;
    enable)              cmd_enable             "$@" ;;
    disable)             cmd_disable            "$@" ;;
    reload)              cmd_reload             "$@" ;;
    list-json)            cmd_list_json          "$@" ;;
    toggle)               cmd_toggle             "$@" ;;
    voices)              cmd_voices             "$@" ;;
    add)                  cmd_add                "$@" ;;
    add-file)             cmd_add_file           "$@" ;;
    edit-rotation)        cmd_edit_rotation      "$@" ;;
    list)                 cmd_list               "$@" ;;
    remove)               cmd_remove             "$@" ;;
    play)                 cmd_play               "$@" ;;
    add-schedule)         cmd_add_schedule       "$@" ;;
    add-schedule-file)    cmd_add_schedule_file  "$@" ;;
    edit-schedule)        cmd_edit_schedule      "$@" ;;
    update-settings)      cmd_update_settings    "$@" ;;
    help|--help|-h) usage ;;
    *)
        echo "Unknown command: $CMD"
        usage
        exit 1
        ;;
esac
