#!/usr/bin/env bash
# herald — management command for asl3-herald

INSTALL_DIR="/etc/asterisk/scripts/asl3-herald"
CONF_FILE="$INSTALL_DIR/asl3-herald.conf"
SERVICE="asl3-herald"
ANNOUNCE_DIR="$INSTALL_DIR/announcements"
DISABLE_FLAG="$INSTALL_DIR/asl3-herald-disabled"
DAEMON_PY="/usr/local/bin/asl3-herald/asl3-herald.py"
PIPER_BIN="/opt/piper/bin/piper/piper"
PIPER_VOICE_DIR="/opt/piper/voices"

usage() {
    cat <<EOF
Usage: herald <command> [options]

General:
  status                                  Show daemon status and config summary
  enable                                  Remove disable flag and start daemon
  disable                                 Stop daemon and set disable flag
  toggle                                  Flip enabled/disabled state
  reload                                  Reload config without restarting (SIGHUP)
  list-json                               Print config as JSON (used by the web UI)
  voices [--json]                         List available TTS voices
  playback-history                        Print recent playback history as JSON
  clear-history                           Clear the playback history
  export-config                           Print the full config as JSON (for backup)
  import-config <path>                    Restore the full config from an exported JSON file
  help                                    Show this message

Tail Messages (unkey-triggered rotation):
  add "<text>" [--name <name>] [--voice <voice>] [--days daily|d1,d2]
      [--time-start HH:MM] [--time-end HH:MM] [--node <n>]
                                           Generate TTS announcement and add to rotation
  add-file <path> [--name <name>] [--days daily|d1,d2] [--time-start HH:MM]
           [--time-end HH:MM] [--node <n>]
                                           Copy an existing WAV file into rotation
  edit-rotation <name> [--new-name <n>] [--text "<text>"] [--voice <v>] [--file <path>]
                [--days daily|d1,d2] [--time-start HH:MM] [--time-end HH:MM] [--node <n>]
                                           Edit an existing rotation entry
  reorder-rotation <name> <up|down>       Move a rotation entry earlier/later in the list
  list                                    List rotation + scheduled announcements
  remove <name>                           Remove a rotation file or scheduled announcement
  play <name>                             Test-play an announcement immediately on the node
                                           (always local playback, ignores PlayMode)

  --days/--time-start/--time-end optionally restrict a rotation entry to only
  be eligible during specific days-of-week and/or a time-of-day window (e.g. a
  net-announcement tail message only eligible on Tuesday evenings). Leave unset
  for a message that's always eligible, like before. --node targets a specific
  node number instead of the daemon's configured Node (for multinodes= setups
  where one AMI connection serves several node numbers).

Scheduled Announcements (clock-triggered):
  add-schedule "<text>" --name <name> --cron "MIN HOUR DOM MON DOW"
               [--voice <voice>] [--play-mode local|global] [--node <n>]
                                           Generate TTS announcement and schedule it
  add-schedule-file <path> --name <name> --cron "MIN HOUR DOM MON DOW"
                     [--play-mode local|global] [--node <n>]
                                           Schedule an existing WAV file
  edit-schedule <name> [--new-name <n>] [--cron "MIN HOUR DOM MON DOW"]
                [--play-mode local|global] [--text "<text>"] [--voice <v>] [--file <path>]
                [--node <n>]
                                           Edit an existing scheduled announcement
  toggle-schedule <name>                   Toggle a scheduled announcement enabled/disabled
  toggle-rotation <name>                   Toggle a tail message rotation entry enabled/disabled

  Cron fields: MIN (0-59)  HOUR (0-23)  DOM (1-31)  MON (1-12)  DOW (0=Sun..6=Sat)
  Use * for every, */n for every-n, n,m for multiple values, n-m for a range.
  Examples:  "30 8 * * *"      daily at 8:30 AM
             "*/20 * * * *"    every 20 minutes
             "30 * * * *"      every hour at :30
             "0 8 * * 1-5"     weekdays at 8:00 AM

  A scheduled announcement waits for the node to unkey before playing if it's
  currently keyed (rather than playing over live traffic), and always takes
  precedence over a tail message due at the same moment.

Settings:
  update-settings [--node <n>] [--debug true|false] [--min-interval <n>]
                  [--network-keyup-trigger true|false]
                  [--swp-enable true|false] [--swp-wxfile <path>]
                  [--swp-threshold <n>]
                                           Update general daemon settings

Hourly Time & Weather (smart-greeting time + current conditions, clock-triggered):
  update-timeweather [--enable true|false] [--time-format 12|24] [--cron "MIN HOUR DOM MON DOW"]
                     [--weather-enable true|false]
                     [--provider auto|metar|openmeteo|tempest|skywarnplus]
                     [--location <zip|icao>] [--temp-unit F|C]
                     [--announce-condition true|false] [--announce-feels-like true|false]
                     [--announce-humidity true|false] [--cache-max-age <minutes>]
                     [--tempest-token <token>] [--tempest-station <id>]
                                           Update Hourly Time & Weather settings
  test-timeweather                        Test-play the announcement immediately
                                           (real weather fetch, doesn't affect the
                                           next scheduled occurrence)

  Takes priority over Scheduled Announcements when both are due at the same
  moment (Scheduled just retries on the next poll cycle), and waits for the
  node to unkey before playing, same as Scheduled Announcements.
EOF
}

need_root() {
    if [[ $EUID -ne 0 ]]; then
        echo "This command requires root. Use: sudo herald $*"
        exit 1
    fi
}

json_get() {
    # json_get <jq-ish python path expression on the parsed dict, e.g. "d['node']">
    python3 -c "
import json, sys
d = json.load(sys.stdin)
try:
    print($1)
except Exception:
    print('')
"
}

daemon_list_json() {
    python3 "$DAEMON_PY" list-json 2>/dev/null
}

get_node() {
    daemon_list_json | json_get "d['node']"
}

# ── TTS generation (shared by add and add-schedule) ───────────────────────────
# Writes text to $ANNOUNCE_DIR/<name>.wav using Piper (preferred), falling back
# to festival or espeak-ng. Prints the resulting file path on success.
generate_tts_file() {
    local text="$1" name="$2" voice="$3"
    mkdir -p "$ANNOUNCE_DIR"
    local outfile="$ANNOUNCE_DIR/${name}.wav"

    if [[ -x "$PIPER_BIN" ]]; then
        local model="$PIPER_VOICE_DIR/en_US-amy-medium.onnx"
        if [[ -n "$voice" ]]; then
            if [[ -f "$PIPER_VOICE_DIR/${voice}.onnx" ]]; then
                model="$PIPER_VOICE_DIR/${voice}.onnx"
            elif [[ -f "$voice" ]]; then
                model="$voice"
            else
                echo "WARNING: voice '$voice' not found, using default (amy)" >&2
            fi
        fi
        local tmp_wav
        tmp_wav="$(mktemp --suffix=.wav)"
        export LD_LIBRARY_PATH="/opt/piper/bin:${LD_LIBRARY_PATH:-}"
        # Piper prints its own status (including the --output_file path) to
        # stdout, which would otherwise get captured by the "outfile=$(...)"
        # call site along with our own final echo below - corrupting the
        # returned path. Suppress it entirely; our own >&2 lines are the
        # only intended diagnostic output.
        echo "$text" | "$PIPER_BIN" --model "$model" --output_file "$tmp_wav" >/dev/null 2>&1
        sox "$tmp_wav" -r 8000 -c 1 -b 16 -t wav "$outfile" >/dev/null 2>&1
        rm -f "$tmp_wav"
        echo "Generated with Piper TTS ($(basename "$model" .onnx)): $outfile" >&2
    elif command -v text2wave &>/dev/null && command -v sox &>/dev/null; then
        local tmp_wav
        tmp_wav="$(mktemp --suffix=.wav)"
        echo "$text" | text2wave -o "$tmp_wav" >/dev/null 2>&1
        sox "$tmp_wav" -r 8000 -c 1 -b 16 -t wav "$outfile" >/dev/null 2>&1
        rm -f "$tmp_wav"
        echo "Generated with festival TTS: $outfile" >&2
    elif command -v espeak-ng &>/dev/null && command -v sox &>/dev/null; then
        espeak-ng -s 140 -a 150 --stdout "$text" 2>/dev/null | sox -t wav - -r 8000 -c 1 -b 16 -t wav "$outfile" >/dev/null 2>&1
        echo "Generated with espeak-ng TTS: $outfile" >&2
    else
        echo "ERROR: No TTS engine found. Install Piper (see install.sh), festival + sox, or espeak-ng + sox." >&2
        return 1
    fi

    if [[ ! -s "$outfile" ]]; then
        echo "ERROR: TTS output file is empty. Check TTS installation." >&2
        return 1
    fi

    echo "$outfile"
}

slugify() {
    echo "$1" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd 'a-z0-9-' | cut -c1-40
}

# ── General commands ───────────────────────────────────────────────────────────

cmd_status() {
    if systemctl is-active --quiet "$SERVICE"; then
        echo "Service:   running"
    else
        echo "Service:   stopped"
    fi

    if [[ -f "$DISABLE_FLAG" ]]; then
        echo "Herald:    DISABLED (disable flag present)"
    else
        echo "Herald:    enabled"
    fi

    local info
    info="$(daemon_list_json)"
    if [[ -n "$info" ]]; then
        echo "Version:   $(echo "$info" | json_get "d['version']")"
        echo "Node:      $(echo "$info" | json_get "d['node']")"
        echo "MinInterval: $(echo "$info" | json_get "d['tail_message']['min_interval']")s"
        echo "SkywarnPlus: $(echo "$info" | json_get "d['tail_message']['skywarnplus']['enable']")"
        echo "Rotation entries:  $(echo "$info" | json_get "len(d['tail_message']['rotation'])")"
        echo "Scheduled entries: $(echo "$info" | json_get "len(d['scheduled'])")"
        echo "Missing files:     $(echo "$info" | json_get "sum(1 for e in d['tail_message']['rotation'] if e.get('FileMissing')) + sum(1 for s in d['scheduled'] if s.get('FileMissing'))")"
    else
        echo "Node:      <config unreadable>"
    fi

    echo ""
    systemctl status "$SERVICE" --no-pager -l 2>&1 | tail -20
}

cmd_enable() {
    need_root "$@"
    if [[ -f "$DISABLE_FLAG" ]]; then
        rm -f "$DISABLE_FLAG"
        echo "Disable flag removed."
    fi
    systemctl start "$SERVICE" 2>/dev/null || true
    systemctl enable "$SERVICE" 2>/dev/null || true
    echo "asl3-herald enabled and started."
}

cmd_disable() {
    need_root "$@"
    touch "$DISABLE_FLAG"
    echo "Disable flag set. Herald will suppress tail messages."
    echo "To also stop the service: sudo systemctl stop $SERVICE"
}

cmd_reload() {
    need_root "$@"
    if systemctl is-active --quiet "$SERVICE"; then
        systemctl kill -s HUP "$SERVICE"
        echo "SIGHUP sent — config reloaded."
    else
        echo "Service is not running. Start it first: sudo systemctl start $SERVICE"
    fi
}

cmd_list_json() {
    # Read-only JSON passthrough for the web UI — no root required.
    daemon_list_json
}

cmd_toggle() {
    need_root "$@"
    if [[ -f "$DISABLE_FLAG" ]]; then
        cmd_enable
    else
        cmd_disable
    fi
}

cmd_voices() {
    local json_mode=false
    [[ "${1:-}" == "--json" ]] && json_mode=true

    if [[ ! -x "$PIPER_BIN" ]]; then
        if $json_mode; then
            echo '{"voices": []}'
        else
            echo "Piper TTS is not installed. Re-run install.sh to add it."
            echo "Falling back to: festival (if installed) or espeak-ng (if installed)."
        fi
        return
    fi

    if $json_mode; then
        local names=()
        if compgen -G "$PIPER_VOICE_DIR/*.onnx" > /dev/null; then
            for f in "$PIPER_VOICE_DIR"/*.onnx; do
                names+=("\"$(basename "$f" .onnx)\"")
            done
        fi
        local joined
        joined=$(IFS=,; echo "${names[*]}")
        echo "{\"voices\": [$joined]}"
        return
    fi

    echo "=== Piper voices ($PIPER_VOICE_DIR) ==="
    if compgen -G "$PIPER_VOICE_DIR/*.onnx" > /dev/null; then
        for f in "$PIPER_VOICE_DIR"/*.onnx; do
            echo "  $(basename "$f" .onnx)"
        done
    else
        echo "  (none installed)"
    fi
}

# ── Tail message (rotation) commands ──────────────────────────────────────────

cmd_add() {
    need_root "$@"
    local text="" name="" voice="" days="daily" time_start="" time_end="" node=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --name)       name="$2";  shift 2 ;;
            --voice)      voice="$2"; shift 2 ;;
            --days)       days="$2";  shift 2 ;;
            --time-start) time_start="$2"; shift 2 ;;
            --time-end)   time_end="$2";   shift 2 ;;
            --node)       node="$2";  shift 2 ;;
            *) text="$1"; shift ;;
        esac
    done

    if [[ -z "$text" ]]; then
        echo "Usage: herald add \"<text>\" [--name <name>] [--voice <voice>] [--days daily|d1,d2] [--time-start HH:MM] [--time-end HH:MM] [--node <n>]"
        exit 1
    fi
    [[ -z "$name" ]] && name="$(slugify "$text")"

    local outfile
    outfile="$(generate_tts_file "$text" "$name" "$voice")" || exit 1

    local args=(add-rotation "$outfile" --text "$text" --days "$days")
    [[ -n "$voice" ]] && args+=(--voice "$voice")
    [[ -n "$time_start" ]] && args+=(--time-start "$time_start")
    [[ -n "$time_end" ]] && args+=(--time-end "$time_end")
    [[ -n "$node" ]] && args+=(--node "$node")
    python3 "$DAEMON_PY" "${args[@]}"
    cmd_reload 2>/dev/null || true
}

cmd_add_file() {
    need_root "$@"
    local src="" name="" days="daily" time_start="" time_end="" node=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --name)       name="$2"; shift 2 ;;
            --days)       days="$2"; shift 2 ;;
            --time-start) time_start="$2"; shift 2 ;;
            --time-end)   time_end="$2";   shift 2 ;;
            --node)       node="$2"; shift 2 ;;
            *) src="$1"; shift ;;
        esac
    done

    if [[ -z "$src" ]]; then
        echo "Usage: herald add-file <path> [--name <name>] [--days daily|d1,d2] [--time-start HH:MM] [--time-end HH:MM] [--node <n>]"
        exit 1
    fi
    if [[ ! -f "$src" ]]; then
        echo "ERROR: File not found: $src"
        exit 1
    fi
    [[ -z "$name" ]] && name="$(basename "$src" .wav)"

    mkdir -p "$ANNOUNCE_DIR"
    local dest="$ANNOUNCE_DIR/${name}.wav"
    cp "$src" "$dest"
    echo "Copied to: $dest"

    local args=(add-rotation "$dest" --days "$days")
    [[ -n "$time_start" ]] && args+=(--time-start "$time_start")
    [[ -n "$time_end" ]] && args+=(--time-end "$time_end")
    [[ -n "$node" ]] && args+=(--node "$node")
    python3 "$DAEMON_PY" "${args[@]}"
    cmd_reload 2>/dev/null || true
}

cmd_edit_rotation() {
    need_root "$@"
    local old_name="" new_name="" text="" voice="" file="" has_text=false has_file=false
    local days="" time_start="" time_end="" node=""
    local has_days=false has_time_start=false has_time_end=false has_node=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --new-name)   new_name="$2"; shift 2 ;;
            --text)       text="$2"; has_text=true; shift 2 ;;
            --voice)      voice="$2"; shift 2 ;;
            --file)       file="$2"; has_file=true; shift 2 ;;
            --days)       days="$2"; has_days=true; shift 2 ;;
            --time-start) time_start="$2"; has_time_start=true; shift 2 ;;
            --time-end)   time_end="$2"; has_time_end=true; shift 2 ;;
            --node)       node="$2"; has_node=true; shift 2 ;;
            *) old_name="$1"; shift ;;
        esac
    done

    if [[ -z "$old_name" ]]; then
        echo 'Usage: herald edit-rotation <name> [--new-name <n>] [--text "<text>"] [--voice <v>] [--file <path>] [--days daily|d1,d2] [--time-start HH:MM] [--time-end HH:MM] [--node <n>]'
        exit 1
    fi
    [[ -z "$new_name" ]] && new_name="$old_name"

    local old_wav="$ANNOUNCE_DIR/${old_name}.wav"
    local new_wav="$ANNOUNCE_DIR/${new_name}.wav"

    if $has_text; then
        generate_tts_file "$text" "$new_name" "$voice" >/dev/null || exit 1
        [[ "$old_name" != "$new_name" && -f "$old_wav" ]] && rm -f "$old_wav"
    elif $has_file; then
        mkdir -p "$ANNOUNCE_DIR"
        cp "$file" "$new_wav"
        [[ "$old_name" != "$new_name" && -f "$old_wav" ]] && rm -f "$old_wav"
    elif [[ "$old_name" != "$new_name" && -f "$old_wav" ]]; then
        # Rename only - no new text/audio, keep the existing file content.
        mv "$old_wav" "$new_wav"
    fi

    local args=(edit-rotation "$old_name" --new-name "$new_name" --file "$new_wav")
    $has_text && args+=(--text "$text")
    [[ -n "$voice" ]] && args+=(--voice "$voice")
    $has_days       && args+=(--days "$days")
    $has_time_start && args+=(--time-start "$time_start")
    $has_time_end   && args+=(--time-end "$time_end")
    $has_node       && args+=(--node "$node")
    python3 "$DAEMON_PY" "${args[@]}"
    cmd_reload 2>/dev/null || true
}

cmd_list() {
    local info
    info="$(daemon_list_json)"
    if [[ -z "$info" ]]; then
        echo "ERROR: Could not read config."
        exit 1
    fi

    echo "=== Tail Messages (Rotation) ==="
    echo "$info" | python3 -c "
import json, sys
d = json.load(sys.stdin)
rot = d['tail_message']['rotation']
if not rot:
    print('  (none)')
for i, e in enumerate(rot, 1):
    f = e.get('File', '') if isinstance(e, dict) else e
    tags = []
    days = e.get('Days') if isinstance(e, dict) else None
    if days and days != 'daily':
        tags.append(','.join(days) if isinstance(days, list) else days)
    start = e.get('TimeStart') if isinstance(e, dict) else None
    end = e.get('TimeEnd') if isinstance(e, dict) else None
    if start or end:
        tags.append(f\"{start or '00:00'}-{end or '23:59'}\")
    node = e.get('Node') if isinstance(e, dict) else None
    if node:
        tags.append(f'node {node}')
    if isinstance(e, dict) and e.get('FileMissing'):
        tags.append('MISSING FILE')
    suffix = f\" ({'; '.join(tags)})\" if tags else ''
    print(f'  {i}. {f}{suffix}')
"

    echo ""
    echo "=== Scheduled Announcements ==="
    echo "$info" | python3 -c "
import json, sys
d = json.load(sys.stdin)
sched = d['scheduled']
if not sched:
    print('  (none)')
for s in sched:
    cron = s.get('Cron', '?')
    node = f\" [node {s['Node']}]\" if s.get('Node') else ''
    missing = ' [MISSING FILE]' if s.get('FileMissing') else ''
    print(f\"  {s.get('Name','?')} — {cron}{node} — {s.get('File','?')}{missing}\")
"
}

cmd_remove() {
    need_root "$@"
    local name="$1"
    if [[ -z "$name" ]]; then
        echo "Usage: herald remove <name>"
        exit 1
    fi

    python3 "$DAEMON_PY" remove "$name"
    cmd_reload 2>/dev/null || true

    local wavfile="$ANNOUNCE_DIR/${name}.wav"
    if [[ -f "$wavfile" ]]; then
        rm -f "$wavfile"
        echo "Deleted: $wavfile"
    fi
}

cmd_update_settings() {
    need_root "$@"
    python3 "$DAEMON_PY" update-settings "$@"
    cmd_reload 2>/dev/null || true
}

cmd_update_timeweather() {
    need_root "$@"
    python3 "$DAEMON_PY" update-timeweather "$@"
    cmd_reload 2>/dev/null || true
}

cmd_test_timeweather() {
    need_root "$@"
    python3 "$DAEMON_PY" test-timeweather
}

cmd_reorder_rotation() {
    need_root "$@"
    local name="$1" direction="$2"
    if [[ -z "$name" || -z "$direction" ]]; then
        echo "Usage: herald reorder-rotation <name> <up|down>"
        exit 1
    fi
    python3 "$DAEMON_PY" reorder-rotation "$name" --direction "$direction"
    cmd_reload 2>/dev/null || true
}

cmd_playback_history() {
    # Read-only JSON passthrough for the web UI — no root required.
    python3 "$DAEMON_PY" playback-history 2>/dev/null
}

cmd_clear_history() {
    need_root "$@"
    python3 "$DAEMON_PY" clear-history 2>/dev/null
}

cmd_export_config() {
    # Read-only JSON passthrough for the web UI — no root required.
    python3 "$DAEMON_PY" export-config 2>/dev/null
}

cmd_import_config() {
    need_root "$@"
    local src="$1"
    if [[ -z "$src" || ! -f "$src" ]]; then
        echo "Usage: herald import-config <path-to-json-file>"
        exit 1
    fi
    python3 "$DAEMON_PY" import-config "$src"
    cmd_reload 2>/dev/null || true
}

cmd_play() {
    need_root "$@"
    local name="$1"
    if [[ -z "$name" ]]; then
        echo "Usage: herald play <name>"
        exit 1
    fi

    local wavfile="$ANNOUNCE_DIR/${name}.wav"
    if [[ ! -f "$wavfile" ]]; then
        echo "ERROR: File not found: $wavfile"
        exit 1
    fi

    local info
    info="$(daemon_list_json)"
    local node
    node="$(echo "$info" | json_get "d['node']")"
    if [[ -z "$node" ]]; then
        echo "ERROR: Node not set in config."
        exit 1
    fi

    # Always plays locally, regardless of a scheduled entry's configured
    # PlayMode - this is a test/preview play, not the entry's real triggered
    # playback (unkey or scheduled time), so it must never actually go out
    # over the network. A Node override (multinodes= setups) is still
    # honored, since that's a targeting concern, not a broadcast-scope one.
    local entry_node
    entry_node="$(echo "$info" | json_get "next((s.get('Node') for s in d['scheduled'] if s.get('Name')=='$name' and s.get('Node')), next((r.get('Node') for r in d['tail_message']['rotation'] if isinstance(r, dict) and r.get('File')=='$wavfile' and r.get('Node')), ''))")"
    [[ -n "$entry_node" ]] && node="$entry_node"

    # Distinguishes a Tail Message test-play from a Scheduled Announcement
    # test-play in the Playback History tab, which otherwise couldn't tell
    # them apart (both used to log as a generic "test" type).
    local entry_kind
    entry_kind="$(echo "$info" | json_get "'scheduled' if any(s.get('Name')=='$name' for s in d['scheduled']) else 'tail'")"

    local path_no_ext="${wavfile%.wav}"
    echo "Testing (local playback) $name on node $node ..."
    asterisk -rx "rpt localplay $node $path_no_ext"
    python3 "$DAEMON_PY" log-playback --type "test-$entry_kind" --name "$name" --file "$wavfile" --node "$node" --play-mode local >/dev/null 2>&1 || true
}

# ── Scheduled announcement commands ───────────────────────────────────────────

parse_schedule_opts() {
    # Parses --name --cron --play-mode --node from "$@",
    # leaving the remainder (text or filepath) in REMAINDER.
    name="" cron="" play_mode="" node=""
    REMAINDER=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --name)      name="$2";      shift 2 ;;
            --cron)      cron="$2";      shift 2 ;;
            --voice)     voice="$2";     shift 2 ;;
            --play-mode) play_mode="$2"; shift 2 ;;
            --node)      node="$2";      shift 2 ;;
            *) REMAINDER+=("$1"); shift ;;
        esac
    done
}

cmd_add_schedule() {
    need_root "$@"
    local name cron voice play_mode node
    parse_schedule_opts "$@"
    local text="${REMAINDER[*]}"

    if [[ -z "$text" || -z "$name" || -z "$cron" ]]; then
        echo 'Usage: herald add-schedule "<text>" --name <name> --cron "MIN HOUR DOM MON DOW" [--voice <voice>] [--play-mode local|global] [--node <n>]'
        exit 1
    fi

    local outfile
    outfile="$(generate_tts_file "$text" "$name" "$voice")" || exit 1

    local args=(add-scheduled --name "$name" --cron "$cron" --file "$outfile" --text "$text")
    [[ -n "$voice" ]] && args+=(--voice "$voice")
    [[ -n "$play_mode" ]] && args+=(--play-mode "$play_mode")
    [[ -n "$node" ]] && args+=(--node "$node")
    python3 "$DAEMON_PY" "${args[@]}"
    cmd_reload 2>/dev/null || true
}

cmd_add_schedule_file() {
    need_root "$@"
    local name cron voice play_mode node
    parse_schedule_opts "$@"
    local src="${REMAINDER[0]:-}"

    if [[ -z "$src" || -z "$name" || -z "$cron" ]]; then
        echo "Usage: herald add-schedule-file <path> --name <name> --cron \"MIN HOUR DOM MON DOW\" [--play-mode local|global] [--node <n>]"
        exit 1
    fi
    if [[ ! -f "$src" ]]; then
        echo "ERROR: File not found: $src"
        exit 1
    fi

    mkdir -p "$ANNOUNCE_DIR"
    local dest="$ANNOUNCE_DIR/${name}.wav"
    cp "$src" "$dest"
    echo "Copied to: $dest"

    local args=(add-scheduled --name "$name" --cron "$cron" --file "$dest")
    [[ -n "$play_mode" ]] && args+=(--play-mode "$play_mode")
    [[ -n "$node" ]] && args+=(--node "$node")
    python3 "$DAEMON_PY" "${args[@]}"
    cmd_reload 2>/dev/null || true
}

cmd_edit_schedule() {
    need_root "$@"
    local old_name="" new_name="" cron="" play_mode="" text="" voice="" file="" node=""
    local has_cron=false has_text=false has_file=false has_playmode=false has_node=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --new-name)  new_name="$2"; shift 2 ;;
            --cron)      cron="$2"; has_cron=true; shift 2 ;;
            --play-mode) play_mode="$2"; has_playmode=true; shift 2 ;;
            --text)      text="$2"; has_text=true; shift 2 ;;
            --voice)     voice="$2"; shift 2 ;;
            --file)      file="$2"; has_file=true; shift 2 ;;
            --node)      node="$2"; has_node=true; shift 2 ;;
            *) old_name="$1"; shift ;;
        esac
    done

    if [[ -z "$old_name" ]]; then
        echo 'Usage: herald edit-schedule <name> [--new-name <n>] [--cron "MIN HOUR DOM MON DOW"] [--play-mode local|global] [--text "<text>"] [--voice <v>] [--file <path>] [--node <n>]'
        exit 1
    fi
    [[ -z "$new_name" ]] && new_name="$old_name"

    local old_wav="$ANNOUNCE_DIR/${old_name}.wav"
    local new_wav="$ANNOUNCE_DIR/${new_name}.wav"
    local final_file=""

    if $has_text; then
        generate_tts_file "$text" "$new_name" "$voice" >/dev/null || exit 1
        final_file="$new_wav"
        [[ "$old_name" != "$new_name" && -f "$old_wav" ]] && rm -f "$old_wav"
    elif $has_file; then
        mkdir -p "$ANNOUNCE_DIR"
        cp "$file" "$new_wav"
        final_file="$new_wav"
        [[ "$old_name" != "$new_name" && -f "$old_wav" ]] && rm -f "$old_wav"
    elif [[ "$old_name" != "$new_name" && -f "$old_wav" ]]; then
        mv "$old_wav" "$new_wav"
        final_file="$new_wav"
    fi

    local args=(edit-scheduled "$old_name" --new-name "$new_name")
    $has_cron     && args+=(--cron "$cron")
    $has_playmode && args+=(--play-mode "$play_mode")
    $has_text     && args+=(--text "$text")
    [[ -n "$voice" ]] && args+=(--voice "$voice")
    [[ -n "$final_file" ]] && args+=(--file "$final_file")
    $has_node     && args+=(--node "$node")

    python3 "$DAEMON_PY" "${args[@]}"
    cmd_reload 2>/dev/null || true
}

cmd_toggle_schedule() {
    need_root "$@"
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        echo "Usage: herald toggle-schedule <name>"
        exit 1
    fi
    python3 "$DAEMON_PY" toggle-scheduled "$name"
    cmd_reload 2>/dev/null || true
}

cmd_toggle_rotation() {
    need_root "$@"
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        echo "Usage: herald toggle-rotation <name>"
        exit 1
    fi
    python3 "$DAEMON_PY" toggle-rotation "$name"
    cmd_reload 2>/dev/null || true
}

