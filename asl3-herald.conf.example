# asl3-herald.conf — Enhanced Tail Message & Announcement Daemon
# Copy to /etc/asterisk/scripts/asl3-herald/asl3-herald.conf and edit.

# Your ASL3 node number (required — install.sh normally prompts for this and
# fills it in automatically; if left blank, the daemon will refuse to start)
Node: ""

# Enable debug logging (set true only for troubleshooting)
Debug: false

# ── Asterisk Manager Interface (AMI) ──────────────────────────────────────────
# AMI enables real-time, low-latency unkey detection and network keyup support.
# The connection is local-only (127.0.0.1) — no internet access involved.
# Herald reads AMI credentials automatically from the system at startup and on
# every SIGHUP reload — you do NOT store them here. Sources, in order:
#   1. /etc/allmon3/allmon3.ini   (Allmon3 users — already configured)
#   2. /etc/asterisk/manager.conf (Supermon / other frontends, or Allmon3 fallback)
# If neither file yields usable credentials, Herald falls back to the legacy
# CLI kerchunk-counter method (local RF unkeys only, ~1s latency).

TailMessage:
  # Enable/disable the tail message function entirely
  Enable: true

  # Minimum seconds between tail messages (prevents rapid replay)
  # This is in SECONDS, not milliseconds like rpt.conf's tailmessagetime.
  # Examples: 5 min = 300 | 10 min = 600 | 15 min = 900
  MinInterval: 300

  # When enabled, tail messages also fire after a network-connected node
  # unkeys (not just local RF). Requires AMI (see above).
  # Default: false (local RF only, matching legacy behavior)
  NetworkKeyupTrigger: true

  # Rotating tail message files (played in order, then repeats). Empty by
  # default — add your own via `herald add`/`herald add-file` or the web UI,
  # or uncomment/edit an example below once the file actually exists.
  # TTS-generated entries also store Text/Voice so they can be edited later
  # (via `herald edit-rotation` or the web UI) without retyping the text;
  # file-uploaded entries just have File and can still be renamed.
  Rotation: []
    # - File: /etc/asterisk/scripts/asl3-herald/announcements/tail1.wav
    #   Text: "This station is running asl3-herald"
    #   Voice: en_US-lessac-medium
    # - File: /etc/asterisk/scripts/asl3-herald/announcements/tail2.wav
    #   Text: null
    #   Voice: null
    # - File: /etc/asterisk/scripts/asl3-herald/announcements/tuesday-net.wav
    #   # Optional: only eligible on the days/time-window given below (omit
    #   # either field for "always eligible", the pre-existing behavior).
    #   Days: ["tuesday"]
    #   TimeStart: "18:00"
    #   TimeEnd: "21:00"
    #   # Optional: target a specific node number instead of this daemon's
    #   # configured Node above (for multinodes= setups where one AMI
    #   # connection serves several node numbers).
    #   Node: "501261"

  SkywarnPlus:
    # Play the SkywarnPlus wx-tail.wav instead of rotation when WX alerts are active.
    # wx-tail.wav is a large file (>5000 bytes) when alerts are present, silent when not.
    # WX alerts always take priority over the rotation.
    Enable: true
    WxTailFile: /tmp/SkywarnPlus/wx-tail.wav
    # File size threshold to distinguish an active alert file from the silent placeholder
    SilenceThreshold: 5000

# Scheduled announcements — play at specific times, regardless of tail message interval
# Days: "daily" or a list: ["saturday", "sunday"]  (case-insensitive)
# Week (optional): 1-5, restricts to the nth week of the month (5 = last week).
#   Omit Week to play on every matching day.
# PlayMode (optional): "local" (default, this node only via `rpt localplay`) or
#   "global" (all connected/linked nodes via `rpt playback`).
# Text/Voice (optional): stored for TTS-generated entries so they can be
#   edited later (via `herald edit-schedule` or the web UI) without retyping.
# Node (optional): target a specific node number instead of this daemon's
#   configured Node above (for multinodes= setups).
# A scheduled announcement waits for the node to unkey before playing if it's
# currently keyed (rather than interrupting live traffic), and always takes
# precedence over a tail message due at the same moment - the tail message
# just retries on its next unkey, with no penalty against MinInterval.
# Empty by default — add your own via `herald add-schedule`/`herald add-schedule-file`
# or the web UI, or uncomment/edit an example below once the file actually exists.
Scheduled: []
  # - Name: "ARRL Audio News"
  #   Time: "07:30"
  #   Days: ["saturday"]
  #   File: /etc/asterisk/scripts/asl3-herald/announcements/arrl-news.wav
  #   PlayMode: local

  # - Name: "Weekly Net Announcement"
  #   Time: "19:45"
  #   Days: ["thursday"]
  #   File: /etc/asterisk/scripts/asl3-herald/announcements/net-announcement.wav
  #   PlayMode: global
  #   Text: "Weekly net announcement text follows"
  #   Voice: en_US-lessac-medium

  # - Name: "Second Saturday Breakfast Net"
  #   Time: "08:00"
  #   Days: ["saturday"]
  #   Week: 2
  #   File: /etc/asterisk/scripts/asl3-herald/announcements/breakfast-net.wav
  #   PlayMode: local
